{
  "global": {},
  "primitive": {
    "color": {
      "bmw-blue": {
        "$type": "color",
        "$value": "#1C69D4"
      },
      "bmw-black": {
        "$type": "color",
        "$value": "#0A0A0A"
      },
      "bmw-white": {
        "$type": "color",
        "$value": "#FFFFFF"
      },
      "surface-dark": {
        "$type": "color",
        "$value": "#1A1A1A"
      },
      "neutral-grey": {
        "$type": "color",
        "$value": "#8C8C8C"
      }
    },
    "font": {
      "family": {
        "primary": {
          "$type": "fontFamilies",
          "$value": "BMW Type Next"
        }
      },
      "weight": {
        "thin": {
          "$type": "fontWeights",
          "$value": "100"
        },
        "light": {
          "$type": "fontWeights",
          "$value": "300"
        },
        "regular": {
          "$type": "fontWeights",
          "$value": "400"
        },
        "medium": {
          "$type": "fontWeights",
          "$value": "500"
        }
      },
      "size": {
        "xs": {
          "$type": "fontSizes",
          "$value": "20"
        },
        "sm": {
          "$type": "fontSizes",
          "$value": "24"
        },
        "md": {
          "$type": "fontSizes",
          "$value": "28"
        },
        "lg": {
          "$type": "fontSizes",
          "$value": "36"
        },
        "xl": {
          "$type": "fontSizes",
          "$value": "48"
        }
      }
    },
    "spacing": {
      "1": {
        "$type": "spacing",
        "$value": "8"
      },
      "2": {
        "$type": "spacing",
        "$value": "12"
      },
      "3": {
        "$type": "spacing",
        "$value": "16"
      },
      "4": {
        "$type": "spacing",
        "$value": "24"
      },
      "5": {
        "$type": "spacing",
        "$value": "32"
      },
      "6": {
        "$type": "spacing",
        "$value": "48"
      },
      "7": {
        "$type": "spacing",
        "$value": "64"
      },
      "8": {
        "$type": "spacing",
        "$value": "80"
      }
    },
    "radius": {
      "none": {
        "$type": "borderRadius",
        "$value": "0"
      },
      "sm": {
        "$type": "borderRadius",
        "$value": "4"
      },
      "md": {
        "$type": "borderRadius",
        "$value": "8"
      },
      "lg": {
        "$type": "borderRadius",
        "$value": "16"
      },
      "full": {
        "$type": "borderRadius",
        "$value": "999"
      }
    },
    "shadow": {
      "sm": {
        "$type": "boxShadow",
        "$value": {
          "x": "0",
          "y": "2",
          "blur": "8",
          "spread": "0",
          "color": "#000000",
          "type": "dropShadow"
        }
      },
      "md": {
        "$type": "boxShadow",
        "$value": {
          "x": "0",
          "y": "4",
          "blur": "16",
          "spread": "0",
          "color": "#000000",
          "type": "innerShadow"
        }
      },
      "lg": {
        "$type": "boxShadow",
        "$value": {
          "x": "0",
          "y": "8",
          "blur": "32",
          "spread": "0",
          "color": "#000000",
          "type": "innerShadow"
        }
      }
    }
  },
  "semantic": {
    "color": {
      "background": {
        "default": {
          "$type": "color",
          "$value": "{color.bmw-black}"
        },
        "surface": {
          "$type": "color",
          "$value": "{color.surface-dark}"
        }
      },
      "text": {
        "primary": {
          "$type": "color",
          "$value": "{color.bmw-white}"
        },
        "secondary": {
          "$type": "color",
          "$value": "{color.neutral-grey}"
        }
      },
      "interactive": {
        "default": {
          "$type": "color",
          "$value": "{color.bmw-blue}"
        }
      }
    },
    "spacing": {
      "touch-target": {
        "$type": "spacing",
        "$value": "{spacing.7}"
      },
      "component": {
        "padding-sm": {
          "$type": "spacing",
          "$value": "{spacing.3}"
        },
        "padding-md": {
          "$type": "spacing",
          "$value": "{spacing.4}"
        },
        "padding-lg": {
          "$type": "spacing",
          "$value": "{spacing.5}"
        }
      },
      "layout": {
        "section": {
          "$type": "spacing",
          "$value": "{spacing.6}"
        }
      }
    },
    "radius": {
      "component": {
        "button": {
          "$type": "borderRadius",
          "$value": "{radius.sm}"
        },
        "card": {
          "$type": "borderRadius",
          "$value": "{radius.md}"
        },
        "modal": {
          "$type": "borderRadius",
          "$value": "{radius.lg}"
        }
      }
    },
    "shadow": {
      "component": {
        "card": {
          "$type": "boxShadow",
          "$value": "{shadow.sm}"
        },
        "modal": {
          "$type": "boxShadow",
          "$value": "{shadow.lg}"
        },
        "button-active": {
          "$type": "boxShadow",
          "$value": "{shadow.md}"
        }
      }
    }
  },
  "driving-mode": {
    "color": {
      "background": {
        "default": {
          "$type": "color",
          "$value": "{color.bmw-black}"
        }
      },
      "text": {
        "primary": {
          "$type": "color",
          "$value": "{color.bmw-white}"
        }
      },
      "interactive": {
        "default": {
          "$type": "color",
          "$value": "{color.bmw-blue}"
        }
      }
    },
    "font": {
      "body": {
        "$type": "fontSizes",
        "$value": "{font.size.lg}"
      },
      "label": {
        "$type": "fontSizes",
        "$value": "{font.size.sm}"
      }
    },
    "spacing": {
      "touch-target": {
        "$type": "spacing",
        "$value": "{spacing.7}"
      }
    }
  },
  "$themes": [],
  "$metadata": {
    "tokenSetOrder": [
      "global",
      "primitive",
      "semantic",
      "driving-mode"
    ]
  }
}