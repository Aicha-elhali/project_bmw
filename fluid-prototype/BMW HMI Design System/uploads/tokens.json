{
  "global": {},
  "primitive": {
    "color": {
      "bmw-blue": {
        "50":  { "$type": "color", "$value": "#E8F1FB" },
        "100": { "$type": "color", "$value": "#C5DBF5" },
        "200": { "$type": "color", "$value": "#8DBAEC" },
        "300": { "$type": "color", "$value": "#5599E2" },
        "400": { "$type": "color", "$value": "#2D7AE8" },
        "500": { "$type": "color", "$value": "#1C69D4" },
        "600": { "$type": "color", "$value": "#1656B0" },
        "700": { "$type": "color", "$value": "#10428A" },
        "800": { "$type": "color", "$value": "#0B2F63" },
        "900": { "$type": "color", "$value": "#071D3D" }
      },
      "neutral": {
        "0":    { "$type": "color", "$value": "#FFFFFF" },
        "50":   { "$type": "color", "$value": "#F2F4F8" },
        "100":  { "$type": "color", "$value": "#D8DEE8" },
        "200":  { "$type": "color", "$value": "#A8B5C8" },
        "300":  { "$type": "color", "$value": "#8C9BB0" },
        "400":  { "$type": "color", "$value": "#5C6B82" },
        "500":  { "$type": "color", "$value": "#3D4A60" },
        "600":  { "$type": "color", "$value": "#2A3548" },
        "700":  { "$type": "color", "$value": "#1B2638" },
        "800":  { "$type": "color", "$value": "#121B2A" },
        "900":  { "$type": "color", "$value": "#0A1428" },
        "950":  { "$type": "color", "$value": "#050B17" }
      },
      "surface": {
        "canvas":          { "$type": "color", "$value": "#0A1428" },
        "canvas-alt":      { "$type": "color", "$value": "#0E1B30" },
        "map-night":       { "$type": "color", "$value": "#0F1A2C" },
        "map-night-alt":   { "$type": "color", "$value": "#1A2840" },
        "elevated":        { "$type": "color", "$value": "#1B2A45" },
        "elevated-alt":    { "$type": "color", "$value": "#243757" },
        "elevated-strong": { "$type": "color", "$value": "#2A4170" },
        "elevated-accent": { "$type": "color", "$value": "#34538D" }
      },
      "status": {
        "warning":  { "$type": "color", "$value": "#F0C040" },
        "warning-strong": { "$type": "color", "$value": "#FFCC00" },
        "danger":   { "$type": "color", "$value": "#E63946" },
        "danger-bright": { "$type": "color", "$value": "#FF4040" },
        "success":  { "$type": "color", "$value": "#3CD278" },
        "info":     { "$type": "color", "$value": "#5BA3FF" }
      },
      "map": {
        "water":       { "$type": "color", "$value": "#1A3A5F" },
        "road-minor":  { "$type": "color", "$value": "#3A4A66" },
        "road-major":  { "$type": "color", "$value": "#FFFFFF" },
        "highway":     { "$type": "color", "$value": "#5BA3FF" },
        "park":        { "$type": "color", "$value": "#1F3540" },
        "traffic-jam": { "$type": "color", "$value": "#FF4040" },
        "route-line":  { "$type": "color", "$value": "#5BA3FF" },
        "user-arrow":  { "$type": "color", "$value": "#1C69D4" }
      }
    },
    "font": {
      "family": {
        "primary":   { "$type": "fontFamilies", "$value": "BMW Type Next" },
        "fallback":  { "$type": "fontFamilies", "$value": "BMW Type Next, system-ui, -apple-system, Segoe UI, Roboto, sans-serif" }
      },
      "weight": {
        "thin":     { "$type": "fontWeights", "$value": "100" },
        "light":    { "$type": "fontWeights", "$value": "300" },
        "regular":  { "$type": "fontWeights", "$value": "400" },
        "medium":   { "$type": "fontWeights", "$value": "500" },
        "bold":     { "$type": "fontWeights", "$value": "700" }
      },
      "size": {
        "2xs": { "$type": "fontSizes", "$value": "12" },
        "xs":  { "$type": "fontSizes", "$value": "14" },
        "sm":  { "$type": "fontSizes", "$value": "16" },
        "md":  { "$type": "fontSizes", "$value": "18" },
        "lg":  { "$type": "fontSizes", "$value": "20" },
        "xl":  { "$type": "fontSizes", "$value": "22" },
        "2xl": { "$type": "fontSizes", "$value": "24" },
        "3xl": { "$type": "fontSizes", "$value": "28" },
        "4xl": { "$type": "fontSizes", "$value": "32" },
        "5xl": { "$type": "fontSizes", "$value": "36" },
        "6xl": { "$type": "fontSizes", "$value": "48" }
      },
      "letter-spacing": {
        "tight":  { "$type": "letterSpacing", "$value": "-0.01em" },
        "normal": { "$type": "letterSpacing", "$value": "0" },
        "wide":   { "$type": "letterSpacing", "$value": "0.02em" },
        "wider":  { "$type": "letterSpacing", "$value": "0.06em" }
      },
      "line-height": {
        "tight":   { "$type": "lineHeights", "$value": "1.1" },
        "snug":    { "$type": "lineHeights", "$value": "1.25" },
        "normal":  { "$type": "lineHeights", "$value": "1.4" },
        "relaxed": { "$type": "lineHeights", "$value": "1.6" }
      }
    },
    "spacing": {
      "0":   { "$type": "spacing", "$value": "0" },
      "0.5": { "$type": "spacing", "$value": "2" },
      "1":   { "$type": "spacing", "$value": "4" },
      "2":   { "$type": "spacing", "$value": "8" },
      "3":   { "$type": "spacing", "$value": "12" },
      "4":   { "$type": "spacing", "$value": "16" },
      "5":   { "$type": "spacing", "$value": "20" },
      "6":   { "$type": "spacing", "$value": "24" },
      "8":   { "$type": "spacing", "$value": "32" },
      "10":  { "$type": "spacing", "$value": "40" },
      "12":  { "$type": "spacing", "$value": "48" },
      "16":  { "$type": "spacing", "$value": "64" },
      "20":  { "$type": "spacing", "$value": "80" },
      "24":  { "$type": "spacing", "$value": "96" }
    },
    "radius": {
      "none": { "$type": "borderRadius", "$value": "0" },
      "sm":   { "$type": "borderRadius", "$value": "4" },
      "md":   { "$type": "borderRadius", "$value": "8" },
      "lg":   { "$type": "borderRadius", "$value": "12" },
      "xl":   { "$type": "borderRadius", "$value": "16" },
      "2xl":  { "$type": "borderRadius", "$value": "24" },
      "full": { "$type": "borderRadius", "$value": "999" }
    },
    "shadow": {
      "card": {
        "$type": "boxShadow",
        "$value": {
          "x": "0", "y": "2", "blur": "8", "spread": "0",
          "color": "rgba(0,0,0,0.4)", "type": "dropShadow"
        }
      },
      "elevated": {
        "$type": "boxShadow",
        "$value": {
          "x": "0", "y": "4", "blur": "16", "spread": "0",
          "color": "rgba(0,0,0,0.5)", "type": "dropShadow"
        }
      },
      "modal": {
        "$type": "boxShadow",
        "$value": {
          "x": "0", "y": "8", "blur": "32", "spread": "0",
          "color": "rgba(0,0,0,0.6)", "type": "dropShadow"
        }
      },
      "glow-primary": {
        "$type": "boxShadow",
        "$value": {
          "x": "0", "y": "0", "blur": "24", "spread": "0",
          "color": "rgba(28,105,212,0.6)", "type": "dropShadow"
        }
      },
      "glow-warning": {
        "$type": "boxShadow",
        "$value": {
          "x": "0", "y": "0", "blur": "16", "spread": "0",
          "color": "rgba(240,192,64,0.4)", "type": "dropShadow"
        }
      },
      "glow-danger": {
        "$type": "boxShadow",
        "$value": {
          "x": "0", "y": "0", "blur": "16", "spread": "0",
          "color": "rgba(230,57,70,0.5)", "type": "dropShadow"
        }
      },
      "inner-card": {
        "$type": "boxShadow",
        "$value": {
          "x": "0", "y": "1", "blur": "0", "spread": "0",
          "color": "rgba(255,255,255,0.06)", "type": "innerShadow"
        }
      }
    },
    "duration": {
      "instant": { "$type": "duration", "$value": "0ms" },
      "fast":    { "$type": "duration", "$value": "150ms" },
      "base":    { "$type": "duration", "$value": "250ms" },
      "slow":    { "$type": "duration", "$value": "400ms" }
    },
    "easing": {
      "standard": { "$type": "cubicBezier", "$value": "cubic-bezier(0.4, 0.0, 0.2, 1)" },
      "decelerate": { "$type": "cubicBezier", "$value": "cubic-bezier(0.0, 0.0, 0.2, 1)" },
      "accelerate": { "$type": "cubicBezier", "$value": "cubic-bezier(0.4, 0.0, 1, 1)" }
    }
  },
  "semantic": {
    "color": {
      "background": {
        "default":         { "$type": "color", "$value": "{color.surface.canvas}" },
        "alt":             { "$type": "color", "$value": "{color.surface.canvas-alt}" },
        "map":             { "$type": "color", "$value": "{color.surface.map-night}" },
        "surface":         { "$type": "color", "$value": "{color.surface.elevated}" },
        "surface-strong":  { "$type": "color", "$value": "{color.surface.elevated-strong}" },
        "surface-accent":  { "$type": "color", "$value": "{color.bmw-blue.500}" }
      },
      "text": {
        "primary":      { "$type": "color", "$value": "{color.neutral.0}" },
        "secondary":    { "$type": "color", "$value": "{color.neutral.200}" },
        "tertiary":     { "$type": "color", "$value": "{color.neutral.400}" },
        "disabled":     { "$type": "color", "$value": "{color.neutral.500}" },
        "accent":       { "$type": "color", "$value": "{color.status.info}" },
        "on-accent":    { "$type": "color", "$value": "{color.neutral.0}" },
        "warning":      { "$type": "color", "$value": "{color.status.warning}" },
        "danger":       { "$type": "color", "$value": "{color.status.danger}" },
        "success":      { "$type": "color", "$value": "{color.status.success}" }
      },
      "interactive": {
        "default":       { "$type": "color", "$value": "{color.bmw-blue.500}" },
        "hover":         { "$type": "color", "$value": "{color.bmw-blue.400}" },
        "pressed":       { "$type": "color", "$value": "{color.bmw-blue.600}" },
        "disabled":      { "$type": "color", "$value": "{color.neutral.600}" },
        "secondary":     { "$type": "color", "$value": "{color.surface.elevated-alt}" },
        "secondary-hover": { "$type": "color", "$value": "{color.surface.elevated-strong}" }
      },
      "border": {
        "default": { "$type": "color", "$value": "rgba(255,255,255,0.08)" },
        "strong":  { "$type": "color", "$value": "rgba(255,255,255,0.16)" },
        "focus":   { "$type": "color", "$value": "{color.bmw-blue.400}" }
      },
      "status": {
        "warning": { "$type": "color", "$value": "{color.status.warning}" },
        "danger":  { "$type": "color", "$value": "{color.status.danger}" },
        "success": { "$type": "color", "$value": "{color.status.success}" },
        "info":    { "$type": "color", "$value": "{color.status.info}" }
      }
    },
    "spacing": {
      "touch-target":      { "$type": "spacing", "$value": "{spacing.16}" },
      "touch-target-sm":   { "$type": "spacing", "$value": "{spacing.12}" },
      "component": {
        "padding-xs": { "$type": "spacing", "$value": "{spacing.2}" },
        "padding-sm": { "$type": "spacing", "$value": "{spacing.3}" },
        "padding-md": { "$type": "spacing", "$value": "{spacing.4}" },
        "padding-lg": { "$type": "spacing", "$value": "{spacing.6}" },
        "padding-xl": { "$type": "spacing", "$value": "{spacing.8}" },
        "gap-xs":     { "$type": "spacing", "$value": "{spacing.1}" },
        "gap-sm":     { "$type": "spacing", "$value": "{spacing.2}" },
        "gap-md":     { "$type": "spacing", "$value": "{spacing.4}" },
        "gap-lg":     { "$type": "spacing", "$value": "{spacing.6}" }
      },
      "layout": {
        "section":      { "$type": "spacing", "$value": "{spacing.12}" },
        "section-lg":   { "$type": "spacing", "$value": "{spacing.20}" },
        "header-height":{ "$type": "spacing", "$value": "{spacing.12}" },
        "footer-height":{ "$type": "spacing", "$value": "{spacing.16}" },
        "side-slot":    { "$type": "spacing", "$value": "{spacing.20}" }
      }
    },
    "radius": {
      "component": {
        "button":        { "$type": "borderRadius", "$value": "{radius.md}" },
        "button-pill":   { "$type": "borderRadius", "$value": "{radius.full}" },
        "input":         { "$type": "borderRadius", "$value": "{radius.md}" },
        "card":          { "$type": "borderRadius", "$value": "{radius.lg}" },
        "card-lg":       { "$type": "borderRadius", "$value": "{radius.xl}" },
        "modal":         { "$type": "borderRadius", "$value": "{radius.xl}" },
        "tab-indicator": { "$type": "borderRadius", "$value": "{radius.full}" },
        "toggle":        { "$type": "borderRadius", "$value": "{radius.full}" },
        "key":           { "$type": "borderRadius", "$value": "{radius.md}" },
        "search":        { "$type": "borderRadius", "$value": "{radius.2xl}" }
      }
    },
    "shadow": {
      "component": {
        "card":          { "$type": "boxShadow", "$value": "{shadow.card}" },
        "card-elevated": { "$type": "boxShadow", "$value": "{shadow.elevated}" },
        "modal":         { "$type": "boxShadow", "$value": "{shadow.modal}" },
        "tab-active":    { "$type": "boxShadow", "$value": "{shadow.glow-primary}" },
        "button-active": { "$type": "boxShadow", "$value": "{shadow.glow-primary}" },
        "warning":       { "$type": "boxShadow", "$value": "{shadow.glow-warning}" },
        "danger":        { "$type": "boxShadow", "$value": "{shadow.glow-danger}" }
      }
    },
    "typography": {
      "page-title":      {
        "size":   { "$type": "fontSizes",   "$value": "{font.size.2xl}" },
        "weight": { "$type": "fontWeights", "$value": "{font.weight.regular}" },
        "tracking": { "$type": "letterSpacing", "$value": "{font.letter-spacing.normal}" }
      },
      "card-heading":    {
        "size":   { "$type": "fontSizes",   "$value": "{font.size.4xl}" },
        "weight": { "$type": "fontWeights", "$value": "{font.weight.light}" }
      },
      "section-heading": {
        "size":   { "$type": "fontSizes",   "$value": "{font.size.2xl}" },
        "weight": { "$type": "fontWeights", "$value": "{font.weight.medium}" }
      },
      "body":            {
        "size":   { "$type": "fontSizes",   "$value": "{font.size.xl}" },
        "weight": { "$type": "fontWeights", "$value": "{font.weight.regular}" }
      },
      "body-secondary":  {
        "size":   { "$type": "fontSizes",   "$value": "{font.size.md}" },
        "weight": { "$type": "fontWeights", "$value": "{font.weight.regular}" }
      },
      "label":           {
        "size":   { "$type": "fontSizes",   "$value": "{font.size.xs}" },
        "weight": { "$type": "fontWeights", "$value": "{font.weight.regular}" },
        "tracking": { "$type": "letterSpacing", "$value": "{font.letter-spacing.wide}" }
      },
      "tab":             {
        "size":   { "$type": "fontSizes",   "$value": "{font.size.xl}" },
        "weight": { "$type": "fontWeights", "$value": "{font.weight.regular}" }
      },
      "climate-temp":    {
        "size":   { "$type": "fontSizes",   "$value": "{font.size.3xl}" },
        "weight": { "$type": "fontWeights", "$value": "{font.weight.light}" }
      },
      "status-label":    {
        "size":   { "$type": "fontSizes",   "$value": "{font.size.2xs}" },
        "weight": { "$type": "fontWeights", "$value": "{font.weight.regular}" },
        "tracking": { "$type": "letterSpacing", "$value": "{font.letter-spacing.wider}" }
      }
    }
  },
  "driving-mode": {
    "_comment": "Token-Overrides für reduzierte Ablenkung im Fahrbetrieb. Größere Touch-Targets, größere Schrift, stärkere Kontraste.",
    "color": {
      "background": {
        "default": { "$type": "color", "$value": "{color.surface.canvas}" }
      },
      "text": {
        "primary": { "$type": "color", "$value": "{color.neutral.0}" }
      },
      "interactive": {
        "default": { "$type": "color", "$value": "{color.bmw-blue.400}" }
      }
    },
    "font": {
      "body":  { "$type": "fontSizes", "$value": "{font.size.5xl}" },
      "label": { "$type": "fontSizes", "$value": "{font.size.2xl}" }
    },
    "spacing": {
      "touch-target": { "$type": "spacing", "$value": "{spacing.20}" }
    }
  },
  "$themes": [],
  "$metadata": {
    "tokenSetOrder": [
      "global",
      "primitive",
      "semantic",
      "driving-mode"
    ]
  }
}
